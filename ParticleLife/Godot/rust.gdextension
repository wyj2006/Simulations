[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 = "res://rust/target/debug/libparticle_life.so"
linux.release.x86_64 = "res://rust/target/release/libparticle_life.so"
windows.debug.x86_64 = "res://rust/target/debug/particle_life.dll"
windows.release.x86_64 = "res://rust/target/release/particle_life.dll"
macos.debug = "res://rust/target/debug/libparticle_life.dylib"
macos.release = "res://rust/target/release/libparticle_life.dylib"
macos.debug.arm64 = "res://rust/target/debug/libparticle_life.dylib"
macos.release.arm64 = "res://rust/target/release/libparticle_life.dylib"
